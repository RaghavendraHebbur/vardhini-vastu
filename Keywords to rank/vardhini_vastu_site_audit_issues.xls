
<html>
<head>
<meta charset="UTF-8">
<style>
  body { font-family: Arial, sans-serif; }
  table { border-collapse: collapse; width: 100%; }
  th { background-color: #1E3A5F; color: white; padding: 10px; border: 1px solid #999; font-weight: bold; }
  td { padding: 8px 10px; border: 1px solid #ccc; vertical-align: top; }
  .error { background-color: #FFE6E6; }
  .error-badge { background-color: #CC0000; color: white; padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; }
  .warning { background-color: #FFF8E1; }
  .warning-badge { background-color: #E6A817; color: white; padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; }
  .notice { background-color: #E8F5E9; }
  .notice-badge { background-color: #2E7D32; color: white; padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; }
  .section-header { background-color: #E8EEF7; font-weight: bold; font-size: 14px; }
  h1 { color: #1E3A5F; }
  .summary { margin-bottom: 20px; background: #f5f5f5; padding: 10px; border-radius: 5px; }
</style>
</head>
<body>
