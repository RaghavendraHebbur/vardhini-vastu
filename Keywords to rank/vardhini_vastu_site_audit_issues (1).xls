   <Column ss:Width="70"/>
   <Column ss:Width="120"/>
   <Column ss:Width="300"/>
   <Column ss:Width="90"/>
   <Column ss:Width="70"/>
   <Column ss:Width="70"/>
   <Column ss:Width="80"/>
   <Column ss:Width="200"/>
   
   <!-- Title Row -->
   <Row ss:Height="28">
    <Cell ss:MergeAcross="8" ss:StyleID="title"><Data ss:Type="String">Vardhini Vastu (vardhinivastu.in) — SEMrush Site Audit Report | Date: May 29, 2026 | Pages Crawled: 396/500</Data></Cell>
   </Row>
   
   <!-- Header Row -->
   <Row ss:Height="22">
    <Cell ss:StyleID="header"><Data ss:Type="String">#</Data></Cell>
    <Cell ss:StyleID="header"><Data ss:Type="String">Severity</Data></Cell>
